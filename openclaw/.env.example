# Supabase project URL
# Found in: Supabase dashboard → Project Settings → API → Project URL
SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase service role key — used by ingestion scripts only
# Found in: Supabase dashboard → Project Settings → API → service_role (secret)
# WARNING: never expose this key in the frontend or commit it to git
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Supabase anon key — reserved for frontend (Next.js) usage
# Found in: Supabase dashboard → Project Settings → API → anon (public)
SUPABASE_ANON_KEY=your-anon-key-here

# Ollama cloud API key — used by ingest.js for summarization
# Found in: ollama.com/settings/keys
OLLAMA_API_KEY=your-ollama-api-key-here
